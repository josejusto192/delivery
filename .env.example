# Supabase (Configurações > API do seu projeto)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Service role (usada só no servidor — nunca exponha no cliente)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Chave de autenticação da API pública (/api/v1/*), usada via header
# "Authorization: Bearer <DELIVERY_API_KEY>" (ex.: integração com n8n)
DELIVERY_API_KEY=defina-uma-chave-secreta-forte

# URL pública do site, usada para montar links de acompanhamento de pedido
NEXT_PUBLIC_SITE_URL=https://delivery.josejusto.com.br
